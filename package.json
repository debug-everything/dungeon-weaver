{
  "name": "dungeon-rpg",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"vite\" \"npm run dev --prefix server\"",
    "dev:client": "vite",
    "dev:server": "npm run dev --prefix server",
    "build": "vite build && cd server && npm install",
    "start": "cd server && npm run start:prod",
    "preview": "vite preview"
  },
  "dependencies": {
    "phaser": "^3.80.1",
    "rot-js": "^2.2.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
