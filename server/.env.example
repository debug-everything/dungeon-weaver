# CORS — comma-separated origins, or * for dev (default: *)
CORS_ORIGIN=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
RATE_LIMIT_LLM_MAX=10
