PORT=4201
DATABASE_PATH=./data/game.db
LOG_LEVEL=info
LLM_ENABLED=false
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_MODEL_FAST=gpt-4.1-nano
